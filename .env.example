# Supabase — copy this file to `.env` and fill in your project's values.
# Find them in Supabase: Dashboard → Project Settings → API.
# Both values are PUBLIC (safe to ship in the client); row-level security
# protects the data. Set the same two vars in Vercel → Project → Settings →
# Environment Variables for the deployed app.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
